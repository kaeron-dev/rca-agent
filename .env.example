# ── LLM ───────────────────────────────────────────────────────────────────
# Modo de ejecución: ollama (local, 16GB+) o gemini (API, 8GB)
LLM_MODE=ollama

# Gemini API Key — gratis en aistudio.google.com, sin tarjeta de crédito
# Solo necesario si LLM_MODE=gemini
GEMINI_API_KEY=your-gemini-api-key-here

# Modelos Gemini
LLM_STANDARD_MODEL=gemini-1.5-flash
LLM_PREMIUM_MODEL=gemini-1.5-pro

# Modelo Ollama local
LLM_LOCAL_MODEL=llama3.2

# ── INFRAESTRUCTURA ────────────────────────────────────────────────────────
TEMPO_URL=http://localhost:3200
PROMETHEUS_URL=http://localhost:9090
OLLAMA_URL=http://ollama:11434

# ── AGENTE ────────────────────────────────────────────────────────────────
# Umbral mínimo de confianza para emitir un RCA report (0.0 - 1.0)
RCA_CONFIDENCE_THRESHOLD=0.75

# Puerto del agente RCA
RCA_AGENT_PORT=8080
